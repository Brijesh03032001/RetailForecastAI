# ── GCP ─────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=my-gcp-project
GCS_BUCKET=my-retail-bucket
BQ_DATASET=retail_forecasting
BQ_LOCATION=US
DATAFLOW_REGION=us-central1

# ── Database ─────────────────────────────────────────────────────
# For local dev use docker-compose (handled by compose override).
# For production use Cloud SQL / AlloyDB and Secret Manager.
DATABASE_URL=postgresql+asyncpg://retail:retail@localhost:5432/retail
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── LLM / Embeddings ─────────────────────────────────────────────
# Local no-cost option:
#   LLM_PROVIDER=openai
#   OPENAI_API_BASE=http://localhost:11434/v1
#   OPENAI_API_KEY=ollama
#   OPENAI_CHAT_MODEL=llama3
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=local

# ── OpenAI or OpenAI-compatible endpoint ─────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_REQUEST_TIMEOUT=60

# ── Groq ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ── RAG ─────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
DOCS_DIR=data/business_docs
CHUNK_SIZE=600
CHUNK_OVERLAP=80
RETRIEVER_TOP_K=5
HUGGINGFACE_EMBED_MODEL=all-MiniLM-L6-v2

# ── Pipeline ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SCHEDULER_SECRET=change-me-before-deploying
FORECAST_HORIZON_DAYS=30

# ── App ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
APP_VERSION=1.0.0
